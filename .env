```env
# ===================================
# A股自选股智能分析系统 - 稳定低超时版
# 针对 GitHub Actions / Docker / 云服务器优化
# ===================================

# ===================================
# 股票列表
# ===================================

STOCK_LIST=688017,601187,002657,600637,002490,600570,000159,000610,002140,603806,002165,603131

# ===================================
# 数据源配置
# ===================================

TUSHARE_TOKEN=

# ===================================
# AI 模型配置
# ===================================

GEMINI_API_KEY=

# ===================================
# 搜索引擎配置（关闭公共搜索实例避免卡死）
# ===================================

ANSPIRE_API_KEYS=
TAVILY_API_KEYS=
SERPAPI_API_KEYS=
BRAVE_API_KEYS=

SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=false

# ===================================
# 新闻时效配置
# ===================================

NEWS_MAX_AGE_DAYS=3

# ===================================
# Agent 配置
# ===================================

AGENT_SKILLS=
AGENT_ORCHESTRATOR_TIMEOUT_S=300
AGENT_SKILL_ROUTING=auto

# ===================================
# 钉钉 / 飞书
# ===================================

DINGTALK_APP_KEY=xxxx
DINGTALK_APP_SECRET=xxxx
DINGTALK_STREAM_ENABLED=false

FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_STREAM_ENABLED=false

# ===================================
# 数据库配置
# ===================================

DATABASE_PATH=./data/stock_analysis.db

SQLITE_WAL_ENABLED=true
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_WRITE_RETRY_MAX=3
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# ===================================
# 回测配置（关闭）
# ===================================

BACKTEST_ENABLED=false

BACKTEST_EVAL_WINDOW_DAYS=10
BACKTEST_MIN_AGE_DAYS=14
BACKTEST_ENGINE_VERSION=v1
BACKTEST_NEUTRAL_BAND_PCT=2.0

# ===================================
# 定时任务
# ===================================

SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00
SCHEDULE_RUN_IMMEDIATELY=true
RUN_IMMEDIATELY=true

# 关闭大盘复盘（非常耗时）
MARKET_REVIEW_ENABLED=false

# ===================================
# 代理配置
# ===================================

USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10809

# ===================================
# 系统配置
# ===================================

LOG_DIR=./logs

LOG_LEVEL=INFO

# 降低并发避免限流
MAX_WORKERS=1

DEBUG=false

# 每只股票间隔
ANALYSIS_DELAY=2

# ===================================
# WebUI
# ===================================

WEBUI_ENABLED=false
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000
WEBUI_AUTO_BUILD=true

# ===================================
# 登录认证
# ===================================

ADMIN_AUTH_ENABLED=false

# ===========================================
# 数据源优先级
# ===========================================

AKSHARE_PRIORITY=0
YFINANCE_PRIORITY=1
EFINANCE_PRIORITY=3

# efinance 超时保护
EFINANCE_CALL_TIMEOUT=10

# ===========================================
# 实时行情配置（关闭）
# ===========================================

ENABLE_REALTIME_QUOTE=false

# 关闭实时技术指标
ENABLE_REALTIME_TECHNICAL_INDICATORS=false

# 关闭筹码分布（东财极易卡死）
ENABLE_CHIP_DISTRIBUTION=false

# 关闭基本面聚合
ENABLE_FUNDAMENTAL_PIPELINE=false

# ===========================================
# 基本面配置
# ===========================================

FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=1.5
FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=0.8
FUNDAMENTAL_RETRY_MAX=1
FUNDAMENTAL_CACHE_TTL_SECONDS=120
FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# 实时数据源优先级
# ===========================================

REALTIME_SOURCE_PRIORITY=tencent,akshare_sina

# ===========================================
# 东财接口补丁（建议开启）
# ===========================================

ENABLE_EASTMONEY_PATCH=true

# ===========================================
# 单股推送
# ===========================================

SINGLE_STOCK_NOTIFY=false

REPORT_TYPE=simple
REPORT_LANGUAGE=zh
REPORT_SUMMARY_ONLY=false

# ===========================================
# 邮件合并
# ===========================================

MERGE_EMAIL_NOTIFICATION=false

# ===========================================
# Markdown 转图片
# ===========================================

MARKDOWN_TO_IMAGE_MAX_CHARS=15000

# ===========================================
# 实时行情预取
# ===========================================

PREFETCH_REALTIME_QUOTES=false

# ===========================================
# Portfolio
# ===========================================

PORTFOLIO_FX_UPDATE_ENABLED=false
```
